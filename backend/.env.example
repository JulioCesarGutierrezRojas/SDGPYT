# Configuración de variables de entorno para producción
# Copiar este archivo como .env en el servidor EC2 y configurar los valores reales

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jira
DB_USER=postgres
DB_PASSWORD=root

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_256_bits_here
JWT_EXPIRATION=86400

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# API Configuration
API_URL=http://your-ec2-public-ip:8080

# CORS Configuration (separar múltiples orígenes con comas)
CORS_ORIGINS=http://your-frontend-url,https://your-frontend-url
