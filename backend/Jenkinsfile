pipeline {
    agent any

    tools {
        maven 'Maven-3.9' // Nombre configurado en Jenkins Global Tool Configuration
        jdk 'JDK-21' // Nombre configurado en Jenkins Global Tool Configuration
    }

    environment {
        // Variables de entorno para EC2
        EC2_HOST = credentials('ec2-host') // IP o DNS de tu EC2
        EC2_USER = credentials('ec2-user') // Usuario SSH (ej: ec2-user, ubuntu)
        SSH_KEY = credentials('ec2-ssh-key') // Credencial de tipo SSH Username with private key

        // Variables de la aplicación
        APP_NAME = 'sdgpyt-backend'
        JAR_NAME = 'backend-0.0.1-SNAPSHOT.jar'
        DEPLOY_DIR = '/home/ec2-user/sdgpyt'

        // Variables de base de datos (usar credentials en Jenkins)
        DB_HOST = credentials('db-host')
        DB_NAME = credentials('db-name')
        DB_USER = credentials('db-user')
        DB_PASSWORD = credentials('db-password')

        // JWT Secret
        JWT_SECRET = credentials('jwt-secret')

        // Email credentials
        EMAIL_USERNAME = credentials('email-username')
        EMAIL_PASSWORD = credentials('email-password')
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Clonando repositorio...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('backend') {
                    echo 'Compilando proyecto con Maven...'
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('backend') {
                    echo 'Ejecutando pruebas...'
                    // Permitir que el build continúe aunque las pruebas fallen
                    script {
                        try {
                            sh 'mvn test'
                        } catch (Exception e) {
                            echo 'Advertencia: Algunas pruebas fallaron, pero continuamos con el build'
                            currentBuild.result = 'UNSTABLE'
                        }
                    }
                }
            }
            post {
                always {
                    // Publicar resultados de pruebas
                    script {
                        try {
                            junit '**/target/surefire-reports/*.xml'
                        } catch (Exception e) {
                            echo 'No se encontraron reportes de pruebas'
                        }
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('backend') {
                    echo 'Empaquetando aplicación...'
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                dir('backend') {
                    echo 'Archivando artefactos...'
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                script {
                    echo 'Desplegando a EC2...'

                    // Crear directorio de deployment en EC2
                    sh """
                        ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${EC2_USER}@${EC2_HOST} '
                            mkdir -p ${DEPLOY_DIR}/logs
                            mkdir -p ${DEPLOY_DIR}/backup
                        '
                    """

                    // Backup del JAR anterior si existe
                    sh """
                        ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${EC2_USER}@${EC2_HOST} '
                            if [ -f ${DEPLOY_DIR}/${JAR_NAME} ]; then
                                cp ${DEPLOY_DIR}/${JAR_NAME} ${DEPLOY_DIR}/backup/${JAR_NAME}.backup.\$(date +%Y%m%d_%H%M%S)
                            fi
                        '
                    """

                    // Copiar JAR a EC2
                    sh """
                        scp -o StrictHostKeyChecking=no -i ${SSH_KEY} \
                            backend/target/${JAR_NAME} \
                            ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/
                    """

                    // Copiar archivo de configuración de producción
                    sh """
                        scp -o StrictHostKeyChecking=no -i ${SSH_KEY} \
                            backend/src/main/resources/application-prod.properties \
                            ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/
                    """

                    // Copiar script de inicio
                    sh """
                        scp -o StrictHostKeyChecking=no -i ${SSH_KEY} \
                            backend/scripts/deploy.sh \
                            ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/
                    """

                    // Hacer ejecutable el script y ejecutarlo
                    sh """
                        ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${EC2_USER}@${EC2_HOST} '
                            chmod +x ${DEPLOY_DIR}/deploy.sh
                            ${DEPLOY_DIR}/deploy.sh
                        '
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    echo 'Verificando que la aplicación esté funcionando...'
                    sleep(time: 30, unit: 'SECONDS') // Esperar 30 segundos para que inicie

                    // Verificar health endpoint
                    sh """
                        ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${EC2_USER}@${EC2_HOST} '
                            curl -f http://localhost:8080/actuator/health || exit 1
                        '
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline ejecutado exitosamente!'
            // Aquí puedes agregar notificaciones por email, Slack, etc.
        }
        failure {
            echo 'Pipeline falló. Revisa los logs.'
            // Notificaciones de fallo
            script {
                // Rollback automático en caso de fallo
                sh """
                    ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${EC2_USER}@${EC2_HOST} '
                        LATEST_BACKUP=\$(ls -t ${DEPLOY_DIR}/backup/*.backup.* 2>/dev/null | head -1)
                        if [ -n "\$LATEST_BACKUP" ]; then
                            echo "Restaurando backup: \$LATEST_BACKUP"
                            cp \$LATEST_BACKUP ${DEPLOY_DIR}/${JAR_NAME}
                            ${DEPLOY_DIR}/deploy.sh
                        fi
                    '
                """
            }
        }
        always {
            cleanWs() // Limpiar workspace
        }
    }
}
